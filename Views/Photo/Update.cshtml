@using PhotoProject.Data


@model PhotoModel;
@{
    ViewData["Title"] = "manage photo";
}

    <body style="background-image: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
        <div class="row">
            <div class="col-md-8 offset-2">

                <div class="row">
                    <div class="col-md-8 offset-2">
                        <form asp-action="Update">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="row">
                                <div class="col-md-6">

                                <div class="form-group">
                                    <label asp-for="AuthorId" class="control-label"></label>
                                    <input asp-for="AuthorId" class="form-control" />
                                    <span asp-validation-for="AuthorId" class="text-danger"></span>
                                </div>
                                    <div class="form-group">
                                        <label asp-for="Name" class="control-label"></label>
                                        <input asp-for="Name" class="form-control" />
                                        <span asp-validation-for="Name" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Tags" class="control-label"></label>
                                    <input asp-for="Tags" class="form-control" />
                                    <span asp-validation-for="Tags" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Camera" class="control-label"></label>
                                        <input asp-for="Camera" class="form-control" />
                                    <span asp-validation-for="Camera" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="ImageURL" class="control-label"></label>
                                        <input asp-for="ImageURL" class="form-control" />
                                        <span asp-validation-for="ImageURL" class="text-danger"></span>
                                    </div>

                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Access" class="control-label"></label>
                                    <select asp-for="Access" class="form-control" asp-items="Html.GetEnumSelectList<AccessLevel>()"></select>
                                    <span asp-validation-for="Access" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Details" class="control-label"></label>
                                    <input asp-for="Details" class="form-control" />
                                    <span asp-validation-for="Details" class="text-danger"></span>
                                    </div>
                                </div>
                              
                            </div>

                            <div class="col-md-4 offset-4 text-center">
                                <div class="body" style="height: 1em"></div>
                            </div>


                            <div class="form-group">
                                <input type="submit" value="Update" class="btn btn-success float-right" style="width: 7em" />
                                <a class="btn btn-secondary" asp-action="Index" style="width: 7em">Show all</a>
                            </div>
                            <div class="col-md-4 offset-4 text-center">
                                <div class="body" style="height:em"></div>
                            </div>
                        </form>
                        <form asp-action="DeleteConfirmed">
                            <div class="form-group">
                                <input asp-for="Id" hidden />
                                <input type="submit" value="Delete" class="btn btn-danger float-right" style="width: 7em" />

                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </body>
